VITE_AUTH_BYPASS=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# CMS — public read API
# Base URL for the Payload CMS REST API. In local dev the Vite proxy rewrites
# /cms/api → http://localhost:3000/api, so no override is needed. In
# production Firebase Hosting rewrites /cms/api/** → the cms-api Cloud Run
# service, so the default also works there. A cross-origin third-party tenant
# would set this to https://haderach.ai/cms/api (or a per-tenant subdomain in V2).
VITE_CMS_API_BASE=/cms/api

# Org slug to scope all public CMS queries to. Defaults to "haderach".
# A second tenant (e.g. acme) would set this to their own slug.
VITE_CMS_ORG_SLUG=haderach
